<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SQL Interactivo — Nivel Medio a Avanzado</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--purple:#3C3489;--purple-mid:#534AB7;--purple-light:#F4F3FD;--teal:#085041;--teal-mid:#0F6E56;--teal-light:#F0FAF6;--blue:#185FA5;--blue-light:#F0F6FD;--amber:#8B5E0A;--amber-light:#FEF9F0;--red:#A32D2D;--red-light:#FCEBEB;--green:#3B6D11;--green-light:#EAF3DE;--border:#e4e4e0;--surface:#fff;--surface-1:#f8f8f6;--surface-0:#f1efe8;--text:#1E1E1C;--text-sec:#5F5E5A;--text-muted:#888780;--mono:'Courier New',monospace}
@media(prefers-color-scheme:dark){:root{--surface:#1a1a18;--surface-1:#222220;--surface-0:#2a2a28;--text:#f0efe8;--text-sec:#b4b2a9;--text-muted:#888780;--border:#3a3a38;--purple-light:#26215C;--teal-light:#04342C;--blue-light:#042C53;--amber-light:#412402;--red-light:#501313;--green-light:#173404}}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--surface-0);color:var(--text);min-height:100vh}
.header{background:var(--purple);color:#fff;padding:14px 20px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:100}
.header h1{font-size:17px;font-weight:600;flex:1}
.hbadge{background:rgba(255,255,255,.2);font-size:11px;padding:3px 9px;border-radius:4px}
.pbar{height:3px;background:rgba(255,255,255,.15)}
.pfill{height:100%;background:#5DCAA5;transition:width .4s}
.layout{display:flex;min-height:calc(100vh - 58px)}
.sidebar{width:230px;min-width:230px;background:var(--surface);border-right:1px solid var(--border);overflow-y:auto;position:sticky;top:58px;height:calc(100vh - 58px)}
.sb-inner{padding:8px}
.mod-label{font-size:10px;font-weight:600;color:var(--text-muted);padding:10px 8px 3px;text-transform:uppercase;letter-spacing:.06em}
.lbtn{display:block;width:100%;text-align:left;background:none;border:none;border-radius:6px;padding:8px 10px;font-size:13px;color:var(--text-sec);cursor:pointer;line-height:1.4;transition:background .12s}
.lbtn:hover{background:var(--surface-1);color:var(--text)}
.lbtn.active{background:var(--blue-light);color:var(--blue);font-weight:500}
.lbtn .num{font-size:10px;color:var(--text-muted);display:block;margin-bottom:1px}
.lbtn.active .num{color:var(--blue);opacity:.7}
.chk{float:right;color:var(--teal-mid);font-size:12px}
.main{flex:1;min-width:0;padding:18px;max-width:820px;margin:0 auto}
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px}
.card-top{padding:16px 18px 0}
.ltitle{font-size:19px;font-weight:600;margin-bottom:5px}
.badge{display:inline-block;font-size:11px;padding:2px 8px;border-radius:4px;font-weight:500;margin-bottom:10px}
.bmed{background:var(--amber-light);color:var(--amber)}
.badv{background:var(--red-light);color:var(--red)}
.tabs{display:flex;border-bottom:1px solid var(--border);padding:0 18px}
.tab{background:none;border:none;border-bottom:2px solid transparent;padding:9px 13px;font-size:13px;color:var(--text-muted);cursor:pointer;font-family:inherit;transition:all .12s;display:flex;align-items:center;gap:5px}
.tab.active{color:var(--blue);border-bottom-color:var(--blue);font-weight:500}
.tcontent{padding:16px 18px}
.btext{font-size:14px;color:var(--text-sec);line-height:1.75;margin-bottom:12px}
.btext b{color:var(--text);font-weight:500}
.btext code{font-family:var(--mono);font-size:12px;background:var(--surface-0);padding:1px 5px;border-radius:3px;color:var(--blue)}
.sqlblock{background:var(--surface-0);border:1px solid var(--border);border-radius:8px;padding:13px 15px;margin:10px 0;font-family:var(--mono);font-size:13px;line-height:1.8;overflow-x:auto;white-space:pre}
.kw{color:#7c5cfc;font-weight:600}.fn{color:#0f6e56;font-weight:500}.str{color:#ba7517}.cmt{color:var(--text-muted);font-style:italic}
.exbox{background:var(--teal-light);border:1px solid #9FE1CB;border-radius:8px;padding:13px 15px;margin-bottom:12px;font-size:13px;color:var(--teal);line-height:1.7}
.exbox code{font-family:var(--mono);font-size:11px;background:rgba(0,0,0,.06);padding:1px 4px;border-radius:3px;display:block;margin-top:6px;white-space:pre-wrap;word-break:break-all}
.spill{display:inline-block;font-size:11px;font-family:var(--mono);background:var(--surface-0);border:1px solid var(--border);border-radius:4px;padding:2px 7px;margin:2px;color:var(--text-sec)}
.ecard{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:14px}
textarea{width:100%;font-family:var(--mono);font-size:13px;background:var(--surface-0);border:1px solid var(--border);border-radius:8px;padding:11px;color:var(--text);resize:vertical;min-height:110px;line-height:1.7;outline:none;transition:border .12s}
textarea:focus{border-color:var(--blue)}
.brow{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;align-items:center}
.btn{border-radius:8px;padding:8px 16px;font-size:13px;font-weight:500;cursor:pointer;font-family:inherit;border:1px solid var(--border);display:inline-flex;align-items:center;gap:5px;transition:all .12s}
.brun{background:var(--blue);color:#fff;border-color:var(--blue)}.brun:hover{background:#0C447C}
.bhint{background:none;color:var(--text-sec)}.bhint:hover{background:var(--surface-1)}
.bnext{background:none;color:var(--blue);border-color:var(--blue);margin-left:auto}.bnext:hover{background:var(--blue-light)}
.result{border-radius:8px;padding:11px 13px;font-size:13px;line-height:1.6;margin-top:10px}
.rok{background:var(--green-light);color:var(--green);border:1px solid #C0DD97}
.rerr{background:var(--red-light);color:var(--red);border:1px solid #F7C1C1}
.rhint{background:var(--amber-light);color:var(--amber);border:1px solid #FAC775}
.navrow{display:flex;justify-content:space-between;align-items:center;margin-top:4px}
.navtxt{font-size:12px;color:var(--text-muted)}
.mobile-strip{display:none;gap:6px;padding:8px 12px;background:var(--surface);border-bottom:1px solid var(--border);overflow-x:auto;position:sticky;top:58px;z-index:90;scrollbar-width:none}
.mobile-strip::-webkit-scrollbar{display:none}
.mchip{white-space:nowrap;border:1px solid var(--border);border-radius:20px;padding:5px 11px;font-size:12px;color:var(--text-sec);background:none;cursor:pointer}
.mchip.active{background:var(--blue-light);border-color:var(--blue);color:var(--blue);font-weight:500}
@media(max-width:640px){.sidebar{display:none}.main{padding:10px}.mobile-strip{display:flex}.card-top{padding:13px 13px 0}.tabs{padding:0 13px}.tcontent{padding:13px}.sqlblock{font-size:12px;padding:10px}.ltitle{font-size:17px}.ecard{padding:12px}}
</style>
</head>
<body>
<div class="header">
  <i class="ti ti-database" style="font-size:21px" aria-hidden="true"></i>
  <h1>SQL Interactivo</h1>
  <span class="hbadge" id="pbadge">0 / 12</span>
</div>
<div class="pbar"><div class="pfill" id="pfill" style="width:0%"></div></div>
<div class="mobile-strip" id="mstrip"></div>
<div class="layout">
  <div class="sidebar"><div class="sb-inner" id="sbinner"></div></div>
  <div class="main">
    <div class="card">
      <div class="card-top">
        <div class="ltitle" id="ltitle"></div>
        <span class="badge" id="lbadge"></span>
      </div>
      <div class="tabs">
        <button class="tab active" onclick="switchTab('learn')"><i class="ti ti-book" aria-hidden="true"></i>Lección</button>
        <button class="tab" onclick="switchTab('exercise')"><i class="ti ti-pencil" aria-hidden="true"></i>Ejercicio</button>
      </div>
      <div class="tcontent" id="tcontent"></div>
    </div>
    <div class="ecard">
      <div style="font-size:13px;font-weight:500;color:var(--text-sec);margin-bottom:8px;display:flex;align-items:center;gap:5px">
        <i class="ti ti-terminal-2" aria-hidden="true"></i>Editor SQL
      </div>
      <textarea id="sqlin" placeholder="-- Escribí tu consulta SQL acá...&#10;SELECT ..."></textarea>
      <div class="brow">
        <button class="btn brun" onclick="runQuery()"><i class="ti ti-player-play" aria-hidden="true"></i>Ejecutar</button>
        <button class="btn bhint" onclick="showHint()"><i class="ti ti-bulb" aria-hidden="true"></i>Pista</button>
        <button class="btn bnext" onclick="nextLesson()">Siguiente<i class="ti ti-arrow-right" aria-hidden="true"></i></button>
      </div>
      <div id="rarea"></div>
    </div>
    <div class="navrow">
      <button class="btn" onclick="prevLesson()" id="bprev"><i class="ti ti-arrow-left" aria-hidden="true"></i>Anterior</button>
      <span class="navtxt" id="navtxt"></span>
      <button class="btn" onclick="nextLesson()">Siguiente<i class="ti ti-arrow-right" aria-hidden="true"></i></button>
    </div>
  </div>
</div>
<script>
const LS=[
{id:0,title:"JOINs avanzados",badge:"med",mod:"Módulo 1 — JOINs",theory:`Los <b>JOINs</b> combinan datos de múltiples tablas. Más allá del INNER JOIN básico, existen variantes esenciales.<br><br><b>INNER JOIN</b> — solo filas con coincidencia en ambas tablas.<br><b>LEFT JOIN</b> — todas las filas de la tabla izquierda, NULL donde no hay coincidencia.<br><b>RIGHT JOIN</b> — inverso del LEFT JOIN.<br><b>FULL OUTER JOIN</b> — todas las filas de ambas tablas.<br><b>SELF JOIN</b> — una tabla se une consigo misma (jerarquías).<br><b>CROSS JOIN</b> — producto cartesiano de todas las combinaciones.`,ex:`<span class="kw">SELECT</span> e.nombre, e.salario, d.nombre <span class="kw">AS</span> departamento\n<span class="kw">FROM</span> empleados e\n<span class="kw">LEFT JOIN</span> departamentos d <span class="kw">ON</span> e.dept_id = d.id\n\n<span class="cmt">-- SELF JOIN: empleado y su manager</span>\n<span class="kw">SELECT</span> e.nombre, m.nombre <span class="kw">AS</span> manager\n<span class="kw">FROM</span> empleados e\n<span class="kw">LEFT JOIN</span> empleados m <span class="kw">ON</span> e.manager_id = m.id`,exercise:`Tenés las tablas: <span class="spill">clientes(id, nombre, ciudad)</span> <span class="spill">pedidos(id, cliente_id, total, fecha)</span><br><br>Mostrá el nombre de <b>todos los clientes</b> con la cantidad de pedidos que tienen. Los clientes sin pedidos deben aparecer con 0.`,kw:["left join","count","group by"],hint:"Usá LEFT JOIN para incluir clientes sin pedidos, y COUNT() con GROUP BY para contar por cliente.",ok:"Perfecto! LEFT JOIN incluye registros sin coincidencia. COUNT(*) cuenta filas, GROUP BY agrupa por cliente."},
{id:1,title:"Subqueries",badge:"med",mod:"Módulo 1 — JOINs",theory:`Una <b>subquery</b> es una consulta dentro de otra. Pueden ir en SELECT, FROM, WHERE o HAVING.<br><br><b>Escalar</b>: devuelve un único valor.<br><b>De lista</b>: devuelve una columna (para IN, NOT IN).<br><b>Correlacionada</b>: referencia la query externa — se ejecuta por cada fila.<br><b>En FROM</b>: se trata como tabla temporal.<br><br>Las subqueries son poderosas pero a veces los JOINs son más eficientes.`,ex:`<span class="cmt">-- Empleados con salario mayor al promedio</span>\n<span class="kw">SELECT</span> nombre, salario\n<span class="kw">FROM</span> empleados\n<span class="kw">WHERE</span> salario > (<span class="kw">SELECT</span> <span class="fn">AVG</span>(salario) <span class="kw">FROM</span> empleados)\n\n<span class="cmt">-- Subquery correlacionada</span>\n<span class="kw">SELECT</span> nombre,\n  (<span class="kw">SELECT</span> <span class="fn">COUNT</span>(*) <span class="kw">FROM</span> pedidos p\n   <span class="kw">WHERE</span> p.cliente_id = c.id) <span class="kw">AS</span> total_pedidos\n<span class="kw">FROM</span> clientes c`,exercise:`Tabla: <span class="spill">productos(id, nombre, precio, categoria)</span><br><br>Devolvé los productos cuyo precio sea mayor al precio promedio de su propia categoría.`,kw:["where","select","avg","categoria"],hint:"Necesitás una subquery correlacionada en WHERE que calcule AVG(precio) filtrando por la misma categoría del producto externo.",ok:"Excelente! La subquery correlacionada referencia la tabla externa filtrando por la misma categoría para comparar con su promedio."},
{id:2,title:"CTEs (WITH)",badge:"med",mod:"Módulo 2 — CTEs y Window",theory:`Los <b>CTEs</b> son consultas temporales nombradas que mejoran la legibilidad. Se definen con <b>WITH</b>.<br><br>Ventajas:<br>• Más legibles y fáciles de mantener.<br>• Se pueden referenciar múltiples veces.<br>• Permiten CTEs encadenadas.<br>• Las CTEs recursivas recorren jerarquías.<br><br>No tienen costo adicional de performance frente a subqueries en la mayoría de los motores.`,ex:`<span class="kw">WITH</span> ventas_mensuales <span class="kw">AS</span> (\n  <span class="kw">SELECT</span>\n    <span class="fn">DATE_TRUNC</span>(<span class="str">'month'</span>, fecha) <span class="kw">AS</span> mes,\n    <span class="fn">SUM</span>(total) <span class="kw">AS</span> total_mes\n  <span class="kw">FROM</span> pedidos\n  <span class="kw">GROUP BY</span> 1\n),\ntop_meses <span class="kw">AS</span> (\n  <span class="kw">SELECT</span> * <span class="kw">FROM</span> ventas_mensuales\n  <span class="kw">WHERE</span> total_mes > 100000\n)\n<span class="kw">SELECT</span> * <span class="kw">FROM</span> top_meses\n<span class="kw">ORDER BY</span> total_mes <span class="kw">DESC</span>`,exercise:`Tablas: <span class="spill">empleados(id, nombre, dept_id, salario)</span> <span class="spill">departamentos(id, nombre)</span><br><br>Usando CTEs, calculá el salario promedio por departamento y mostrá solo los que superan $60.000.`,kw:["with","avg","group by"],hint:"Creá un CTE que calcule AVG(salario) GROUP BY dept_id, luego JOIN con departamentos y filtrá los que superan 60000.",ok:"Muy bien! WITH ... AS (...) organiza el SQL en etapas lógicas. Podés encadenar varios CTEs separados por coma."},
{id:3,title:"Window Functions — Básico",badge:"med",mod:"Módulo 2 — CTEs y Window",theory:`Las <b>Window Functions</b> calculan sobre filas relacionadas sin colapsar el resultado con GROUP BY.<br><br>Sintaxis: <code>funcion() OVER (PARTITION BY col ORDER BY col)</code><br><br><b>PARTITION BY</b>: divide en grupos (ventanas). Si se omite, todas las filas son una ventana.<br><b>ORDER BY</b>: ordena dentro de cada ventana.<br><br>Funciones: <code>ROW_NUMBER()</code>, <code>RANK()</code>, <code>DENSE_RANK()</code>, <code>SUM()</code>, <code>AVG()</code>, <code>LAG()</code>, <code>LEAD()</code>.`,ex:`<span class="cmt">-- Ranking de ventas por región</span>\n<span class="kw">SELECT</span>\n  vendedor, region, monto,\n  <span class="fn">RANK</span>() <span class="kw">OVER</span> (\n    <span class="kw">PARTITION BY</span> region\n    <span class="kw">ORDER BY</span> monto <span class="kw">DESC</span>\n  ) <span class="kw">AS</span> ranking,\n  <span class="fn">SUM</span>(monto) <span class="kw">OVER</span> (<span class="kw">PARTITION BY</span> region) <span class="kw">AS</span> total_region\n<span class="kw">FROM</span> ventas`,exercise:`Tabla: <span class="spill">ventas(vendedor, region, monto, mes)</span><br><br>Mostrá para cada vendedor su monto de ventas y su ranking dentro de su región (1 = mayor vendedor). Usá RANK().`,kw:["rank","over","partition by","order by"],hint:"RANK() OVER (PARTITION BY region ORDER BY monto DESC) asigna el ranking dentro de cada región. No necesitás GROUP BY.",ok:"Excelente! RANK() asigna el mismo número a empates y salta el siguiente (1,1,3). DENSE_RANK() no salta (1,1,2). ROW_NUMBER() da números únicos."},
{id:4,title:"Window — LAG y LEAD",badge:"adv",mod:"Módulo 2 — CTEs y Window",theory:`<b>LAG()</b> y <b>LEAD()</b> acceden a filas anteriores o siguientes sin necesidad de un self-join.<br><br><code>LAG(col, n, default)</code> → valor de n filas hacia atrás.<br><code>LEAD(col, n, default)</code> → valor de n filas hacia adelante.<br><br>Útiles para:<br>• Variaciones mes a mes (MoM).<br>• Tiempo entre eventos.<br>• Comparar con el período anterior.<br><br>El tercer parámetro es el valor cuando no hay fila anterior/siguiente.`,ex:`<span class="cmt">-- Variación de ventas mes a mes</span>\n<span class="kw">SELECT</span>\n  mes, ventas,\n  <span class="fn">LAG</span>(ventas) <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> mes) <span class="kw">AS</span> mes_anterior,\n  ventas - <span class="fn">LAG</span>(ventas) <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> mes) <span class="kw">AS</span> variacion,\n  <span class="fn">ROUND</span>(\n    (ventas - <span class="fn">LAG</span>(ventas) <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> mes)) * 100.0\n    / <span class="fn">LAG</span>(ventas) <span class="kw">OVER</span> (<span class="kw">ORDER BY</span> mes), 2\n  ) <span class="kw">AS</span> variacion_pct\n<span class="kw">FROM</span> ventas_mensuales`,exercise:`Tabla: <span class="spill">metricas(producto, mes, revenue)</span><br><br>Calculá el revenue actual, el del mes anterior (LAG) y el crecimiento porcentual MoM por producto. Mostrá solo los registros con crecimiento mayor al 10%.`,kw:["lag","over","partition by","order by"],hint:"Usá LAG(revenue) OVER (PARTITION BY producto ORDER BY mes). Para filtrar el % usá un CTE y filtrá en la query externa.",ok:"Perfecto! Combinando CTEs con LAG() podés hacer análisis de tendencias muy potentes."},
{id:5,title:"HAVING vs WHERE",badge:"med",mod:"Módulo 3 — Agregaciones",theory:`<b>WHERE</b> filtra filas <i>antes</i> de agregar. <b>HAVING</b> filtra <i>después</i> de agregar.<br><br>Orden de ejecución:<br>1. FROM → 2. WHERE → 3. GROUP BY → 4. Agregaciones → 5. HAVING → 6. SELECT → 7. ORDER BY → 8. LIMIT<br><br><b>Regla:</b> si el filtro usa una función de agregación (SUM, COUNT, AVG...) → HAVING. Si filtra columnas normales → WHERE.`,ex:`<span class="cmt">-- WHERE filtra ANTES de agrupar</span>\n<span class="kw">SELECT</span> categoria, <span class="fn">COUNT</span>(*) <span class="kw">AS</span> total\n<span class="kw">FROM</span> productos\n<span class="kw">WHERE</span> precio > 100\n<span class="kw">GROUP BY</span> categoria\n<span class="kw">HAVING</span> <span class="fn">COUNT</span>(*) > 5`,exercise:`Tabla: <span class="spill">ordenes(cliente_id, producto, monto, fecha)</span><br><br>Encontrá clientes que en 2024 hicieron más de 5 compras Y cuyo monto promedio supera $500. Mostrá cliente_id, cantidad y promedio.`,kw:["having","group by","count","avg"],hint:"WHERE filtra por 2024. GROUP BY cliente_id. HAVING usa COUNT(*) > 5 AND AVG(monto) > 500.",ok:"Correcto! WHERE filtra las filas. GROUP BY agrupa. HAVING filtra los grupos que cumplen las condiciones de agregación."},
{id:6,title:"Funciones de fecha",badge:"med",mod:"Módulo 3 — Agregaciones",theory:`Las funciones de fecha varían según el motor, pero los conceptos son consistentes.<br><br><b>PostgreSQL / BigQuery:</b><br><code>DATE_TRUNC('month', fecha)</code> — trunca al inicio del mes.<br><code>EXTRACT(year FROM fecha)</code> — extrae el año.<br><code>fecha + INTERVAL '7 days'</code><br><br><b>MySQL:</b><br><code>DATE_FORMAT(fecha, '%Y-%m')</code><br><code>DATEDIFF(fecha1, fecha2)</code><br><br><b>SQL Server:</b><br><code>DATEPART(month, fecha)</code><br><code>DATEDIFF(day, fecha1, fecha2)</code>`,ex:`<span class="cmt">-- Ventas por mes (PostgreSQL)</span>\n<span class="kw">SELECT</span>\n  <span class="fn">DATE_TRUNC</span>(<span class="str">'month'</span>, fecha) <span class="kw">AS</span> mes,\n  <span class="fn">COUNT</span>(*) <span class="kw">AS</span> pedidos,\n  <span class="fn">SUM</span>(total) <span class="kw">AS</span> revenue\n<span class="kw">FROM</span> pedidos\n<span class="kw">WHERE</span> fecha >= <span class="str">'2024-01-01'</span>\n  <span class="kw">AND</span> fecha < <span class="str">'2025-01-01'</span>\n<span class="kw">GROUP BY</span> 1\n<span class="kw">ORDER BY</span> 1`,exercise:`Tabla: <span class="spill">sesiones(usuario_id, inicio, fin, plataforma)</span><br><br>Calculá la duración promedio en minutos por plataforma, solo para sesiones del Q4 2024. Mostrá solo plataformas con promedio mayor a 10 minutos.`,kw:["avg","group by","having","where"],hint:"Calculá la duración como diferencia entre fin e inicio. Filtrá por fecha en WHERE. GROUP BY plataforma y HAVING AVG > 10.",ok:"Muy bien! Recordá usar rangos de fecha con >= y < para incluir/excluir correctamente."},
{id:7,title:"CASE WHEN",badge:"med",mod:"Módulo 3 — Agregaciones",theory:`<b>CASE WHEN</b> es el if/else del SQL. Crea columnas condicionales.<br><br>Usos comunes:<br>• Crear categorías o segmentos numéricos.<br>• Pivotear datos (filas en columnas).<br>• Contar condicionalmente: <code>COUNT(CASE WHEN ... THEN 1 END)</code>.<br>• Asignar pesos o scores.`,ex:`<span class="kw">SELECT</span> cliente_id, total_compras,\n  <span class="kw">CASE</span>\n    <span class="kw">WHEN</span> total_compras >= 10000 <span class="kw">THEN</span> <span class="str">'VIP'</span>\n    <span class="kw">WHEN</span> total_compras >= 1000  <span class="kw">THEN</span> <span class="str">'Premium'</span>\n    <span class="kw">WHEN</span> total_compras >= 100   <span class="kw">THEN</span> <span class="str">'Regular'</span>\n    <span class="kw">ELSE</span> <span class="str">'Nuevo'</span>\n  <span class="kw">END</span> <span class="kw">AS</span> segmento\n<span class="kw">FROM</span> clientes\n\n<span class="cmt">-- Pivot: contar por categoría en columnas</span>\n<span class="kw">SELECT</span> mes,\n  <span class="fn">COUNT</span>(<span class="kw">CASE WHEN</span> cat=<span class="str">'A'</span> <span class="kw">THEN</span> 1 <span class="kw">END</span>) <span class="kw">AS</span> cat_a,\n  <span class="fn">COUNT</span>(<span class="kw">CASE WHEN</span> cat=<span class="str">'B'</span> <span class="kw">THEN</span> 1 <span class="kw">END</span>) <span class="kw">AS</span> cat_b\n<span class="kw">FROM</span> ventas <span class="kw">GROUP BY</span> mes`,exercise:`Tabla: <span class="spill">empleados(id, nombre, salario)</span><br><br>Clasificá a cada empleado: 'Junior' (< $40k), 'Mid' ($40k-$80k), 'Senior' ($80k-$120k), 'Lead' (> $120k). Luego contá cuántos hay en cada banda.`,kw:["case when","group by","count"],hint:"Usá CASE WHEN en el SELECT para crear 'banda'. Luego envolvé en un CTE y hacé GROUP BY banda, COUNT(*).",ok:"Excelente! CASE WHEN es una de las herramientas más usadas en SQL analítico. GROUP BY + COUNT sobre una columna CASE es el patrón estándar de segmentación."},
{id:8,title:"Índices y performance",badge:"adv",mod:"Módulo 4 — Performance",theory:`Los <b>índices</b> aceleran búsquedas sin cambiar los datos.<br><br><b>Tipos:</b><br>• <b>B-Tree</b>: el más común. Para =, >, <, BETWEEN, ORDER BY.<br>• <b>Hash</b>: solo para igualdad (=).<br>• <b>GIN/GiST</b>: para arrays, JSON, texto completo (PostgreSQL).<br>• <b>Compuesto</b>: múltiples columnas. El orden importa.<br><br><b>Cuándo NO ayuda:</b><br>• Tablas pequeñas.<br>• Baja cardinalidad (pocos valores distintos).<br>• Funciones sobre la columna indexada.<br>• INSERTs/UPDATEs muy frecuentes.`,ex:`<span class="kw">CREATE INDEX</span> idx_pedidos_cliente\n  <span class="kw">ON</span> pedidos(cliente_id);\n\n<span class="kw">CREATE INDEX</span> idx_pedidos_fecha_estado\n  <span class="kw">ON</span> pedidos(fecha, estado);\n\n<span class="cmt">-- EXPLAIN ANALYZE: ver el plan de ejecución</span>\n<span class="kw">EXPLAIN ANALYZE</span>\n<span class="kw">SELECT</span> * <span class="kw">FROM</span> pedidos\n<span class="kw">WHERE</span> cliente_id = 123\n\n<span class="cmt">-- MALO: función anula el índice</span>\n<span class="kw">WHERE</span> <span class="fn">UPPER</span>(nombre) = <span class="str">'JUAN'</span>\n<span class="cmt">-- BIEN: comparación directa</span>\n<span class="kw">WHERE</span> nombre = <span class="str">'juan'</span>`,exercise:`Tabla: <span class="spill">eventos(id, usuario_id, tipo, fecha, payload JSONB)</span> con 50 millones de filas.<br><br>Las queries más frecuentes filtran por usuario_id y fecha. Escribí los CREATE INDEX apropiados y explicá el orden de columnas elegido.`,kw:["create index","on","usuario_id","fecha"],hint:"Un índice compuesto (usuario_id, fecha) sirve para queries con solo usuario_id (usa el prefijo) y para queries con ambas. La columna de igualdad va primero.",ok:"Correcto! El índice (usuario_id, fecha) es más eficiente que dos índices separados. Un índice (fecha, usuario_id) no serviría para queries que filtran solo por usuario_id."},
{id:9,title:"CTEs recursivas",badge:"adv",mod:"Módulo 4 — Performance",theory:`Las <b>CTEs recursivas</b> recorren estructuras jerárquicas directamente en SQL. Ideales para organigramas, categorías anidadas, BOM en manufactura.<br><br>Estructura:<br>1. <b>Anchor query</b>: la fila inicial (raíz del árbol).<br>2. <b>UNION ALL</b>: une el anchor con la parte recursiva.<br>3. <b>Recursive query</b>: se une con el CTE mismo para bajar niveles.<br><br>El motor repite la recursión hasta que la parte recursiva no devuelve filas.`,ex:`<span class="kw">WITH RECURSIVE</span> jerarquia <span class="kw">AS</span> (\n  <span class="cmt">-- Anchor: el CEO (sin manager)</span>\n  <span class="kw">SELECT</span> id, nombre, manager_id, 0 <span class="kw">AS</span> nivel\n  <span class="kw">FROM</span> empleados\n  <span class="kw">WHERE</span> manager_id <span class="kw">IS NULL</span>\n\n  <span class="kw">UNION ALL</span>\n\n  <span class="cmt">-- Recursión: hijos del nivel actual</span>\n  <span class="kw">SELECT</span> e.id, e.nombre, e.manager_id, j.nivel + 1\n  <span class="kw">FROM</span> empleados e\n  <span class="kw">JOIN</span> jerarquia j <span class="kw">ON</span> e.manager_id = j.id\n)\n<span class="kw">SELECT</span> nombre, nivel <span class="kw">FROM</span> jerarquia\n<span class="kw">ORDER BY</span> nivel, nombre`,exercise:`Tabla: <span class="spill">categorias(id, nombre, padre_id)</span><br><br>Escribí una CTE recursiva que devuelva todas las subcategorías de la categoría id = 1, incluyendo el nivel de profundidad (nivel 0 = raíz).`,kw:["with recursive","union all","padre_id","nivel"],hint:"Anchor: categoría con id = 1 y nivel = 0. Recursión: JOIN de categorias con el CTE usando padre_id = id del CTE, sumando nivel + 1.",ok:"Muy bien! Las CTEs recursivas son la forma estándar de recorrer jerarquías en SQL sin procesar en la aplicación."},
{id:10,title:"Transacciones y ACID",badge:"adv",mod:"Módulo 5 — Avanzado",theory:`Una <b>transacción</b> es un conjunto de operaciones que se ejecutan como una unidad atómica. Las propiedades ACID garantizan la integridad:<br><br><b>A</b>tomicity: todo o nada. Si algo falla, se revierte todo.<br><b>C</b>onsistency: la BD va de un estado válido a otro válido.<br><b>I</b>solation: las transacciones concurrentes no se interfieren.<br><b>D</b>urability: los cambios confirmados persisten aunque falle el sistema.<br><br><b>Niveles de aislamiento:</b><br>• READ UNCOMMITTED → READ COMMITTED → REPEATABLE READ → SERIALIZABLE`,ex:`<span class="kw">BEGIN</span>;\n\n<span class="kw">UPDATE</span> cuentas\n  <span class="kw">SET</span> saldo = saldo - 1000\n  <span class="kw">WHERE</span> id = 42;\n\n<span class="kw">UPDATE</span> cuentas\n  <span class="kw">SET</span> saldo = saldo + 1000\n  <span class="kw">WHERE</span> id = 99;\n\n<span class="kw">COMMIT</span>; <span class="cmt">-- confirma ambas</span>\n<span class="cmt">-- ROLLBACK; revierte ambas si algo falla</span>\n\n<span class="kw">SAVEPOINT</span> punto_1;\n<span class="kw">ROLLBACK TO</span> punto_1;`,exercise:`Escribí en SQL (con comentarios) una transacción para procesar una compra: (1) verificar stock, (2) descontar stock, (3) crear pedido, (4) cobrar al cliente.<br><br>¿Qué pasa si el cobro falla?`,kw:["begin","commit","rollback","update","insert"],hint:"Usá BEGIN para iniciar. Si el cobro falla, ROLLBACK revierte tanto el descuento de stock como la creación del pedido.",ok:"Perfecto! Las transacciones garantizan atomicidad: nunca queda el stock descontado sin el pedido creado. O todo sucede, o nada sucede."},
{id:11,title:"Optimización de queries",badge:"adv",mod:"Módulo 5 — Avanzado",theory:`Escribir SQL eficiente es clave en producción. Errores comunes:<br><br><b>1. SELECT *</b>: trae columnas innecesarias, aumenta I/O.<br><b>2. Funciones en WHERE sobre columnas indexadas</b>: anula el índice.<br><b>3. OR vs IN</b>: OR puede no usar índices eficientemente.<br><b>4. Subqueries correlacionadas en SELECT</b>: se ejecutan N veces.<br><b>5. DISTINCT innecesario</b>: costoso, indica JOIN mal diseñado.<br><b>6. NOT IN con NULLs</b>: resultados inesperados.<br><br><code>EXPLAIN ANALYZE</code> es tu mejor amigo. Buscá "Seq Scan" en tablas grandes → falta un índice.`,ex:`<span class="cmt">-- MALO: función anula índice</span>\n<span class="kw">WHERE</span> <span class="fn">YEAR</span>(fecha) = 2024\n\n<span class="cmt">-- BIEN: rango usa el índice</span>\n<span class="kw">WHERE</span> fecha >= <span class="str">'2024-01-01'</span>\n  <span class="kw">AND</span> fecha < <span class="str">'2025-01-01'</span>\n\n<span class="cmt">-- MALO: subquery correlacionada N veces</span>\n<span class="kw">SELECT</span> nombre,\n  (<span class="kw">SELECT</span> <span class="fn">COUNT</span>(*) <span class="kw">FROM</span> pedidos\n   <span class="kw">WHERE</span> cliente_id = c.id)\n<span class="kw">FROM</span> clientes c\n\n<span class="cmt">-- BIEN: JOIN con subquery agregada</span>\n<span class="kw">SELECT</span> c.nombre, p.total\n<span class="kw">FROM</span> clientes c\n<span class="kw">LEFT JOIN</span> (<span class="kw">SELECT</span> cliente_id, <span class="fn">COUNT</span>(*) total\n            <span class="kw">FROM</span> pedidos <span class="kw">GROUP BY</span> 1) p\n  <span class="kw">ON</span> p.cliente_id = c.id`,exercise:`Recibís esta query lenta:<br><br><code>SELECT DISTINCT c.nombre, COUNT(*) FROM clientes c, pedidos p WHERE c.id = p.cliente_id AND YEAR(p.fecha) = 2024 AND c.pais IN (SELECT pais FROM paises_activos) GROUP BY c.nombre</code><br><br>Identificá 3 problemas y reescribila optimizada.`,kw:["join","where","group by"],hint:"Problemas: (1) JOIN implícito con coma, (2) YEAR() sobre columna indexada, (3) subquery IN. Reescribí con JOIN explícito, rango de fecha y JOIN para países.",ok:"Excelente! Los cambios más impactantes: JOIN explícito, rango de fechas en lugar de función, subquery convertida a JOIN."},
];

const done=new Set();let cur=0,tab='learn';

function render(){
  const l=LS[cur];
  document.getElementById('ltitle').textContent=l.title;
  const b=document.getElementById('lbadge');
  b.textContent=l.badge==='med'?'Nivel medio':'Nivel avanzado';
  b.className='badge '+(l.badge==='med'?'bmed':'badv');
  document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('active',(i===0&&tab==='learn')||(i===1&&tab==='exercise')));
  const c=document.getElementById('tcontent');
  if(tab==='learn'){
    c.innerHTML=`<div class="btext">${l.theory}</div>
    <div style="font-size:13px;font-weight:500;color:var(--text-sec);margin:10px 0 4px"><i class="ti ti-code" aria-hidden="true"></i> Ejemplo:</div>
    <div class="sqlblock">${l.ex}</div>
    <div style="margin-top:12px;padding:9px 13px;background:var(--teal-light);border-radius:8px;font-size:13px;color:var(--teal-mid)">
      <i class="ti ti-arrow-right" aria-hidden="true"></i> Tocá <b>Ejercicio</b> para practicar.</div>`;
  } else {
    c.innerHTML=`<div style="font-size:13px;font-weight:500;color:var(--text-sec);margin-bottom:8px"><i class="ti ti-pencil" aria-hidden="true"></i> Ejercicio ${l.id+1} de ${LS.length}</div>
    <div class="exbox">${l.exercise}</div>
    <div style="font-size:12px;color:var(--text-muted)">Escribí tu solución abajo y tocá Ejecutar.</div>`;
  }
  const pct=Math.round(done.size/LS.length*100);
  document.getElementById('pfill').style.width=pct+'%';
  document.getElementById('pbadge').textContent=`${done.size} / ${LS.length}`;
  document.getElementById('navtxt').textContent=`Lección ${cur+1} de ${LS.length}`;
  document.getElementById('bprev').style.visibility=cur===0?'hidden':'visible';
  renderSidebar();
}

function renderSidebar(){
  const sb=document.getElementById('sbinner');
  const ms=document.getElementById('mstrip');
  const mods={};
  LS.forEach(l=>{if(!mods[l.mod])mods[l.mod]=[];mods[l.mod].push(l);});
  sb.innerHTML='';ms.innerHTML='';
  Object.entries(mods).forEach(([m,ls])=>{
    const g=document.createElement('div');
    g.innerHTML=`<div class="mod-label">${m}</div>`;
    ls.forEach(l=>{
      const btn=document.createElement('button');
      btn.className='lbtn'+(l.id===cur?' active':'');
      btn.innerHTML=`<span class="num">Lección ${l.id+1}</span>${l.title}${done.has(l.id)?'<span class="chk">✓</span>':''}`;
      btn.onclick=()=>loadLesson(l.id);
      g.appendChild(btn);
      const mc=document.createElement('button');
      mc.className='mchip'+(l.id===cur?' active':'');
      mc.textContent=`${l.id+1}. ${l.title}`;
      mc.onclick=()=>loadLesson(l.id);
      ms.appendChild(mc);
    });
    sb.appendChild(g);
  });
}

function loadLesson(id){cur=id;tab='learn';document.getElementById('rarea').innerHTML='';document.getElementById('sqlin').value='';render();window.scrollTo({top:0,behavior:'smooth'});}
function switchTab(t){tab=t;render();}
function runQuery(){
  const sql=document.getElementById('sqlin').value.trim().toLowerCase();
  const l=LS[cur];const ra=document.getElementById('rarea');
  if(!sql){ra.innerHTML='<div class="result rerr">Escribí una consulta antes de ejecutar.</div>';return;}
  const m=l.kw.filter(k=>sql.includes(k));
  if(m.length/l.kw.length>=0.7){done.add(cur);ra.innerHTML=`<div class="result rok"><b>✓ ¡Correcto!</b> ${l.ok}</div>`;renderSidebar();}
  else{const miss=l.kw.filter(k=>!sql.includes(k));ra.innerHTML=`<div class="result rerr"><b>No del todo.</b> Parece que falta: <code>${miss.join(', ')}</code>. Revisá y probá de nuevo.</div>`;}
}
function showHint(){document.getElementById('rarea').innerHTML=`<div class="result rhint"><b>Pista:</b> ${LS[cur].hint}</div>`;}
function nextLesson(){if(cur<LS.length-1)loadLesson(cur+1);}
function prevLesson(){if(cur>0)loadLesson(cur-1);}

render();
</script>
</body>
